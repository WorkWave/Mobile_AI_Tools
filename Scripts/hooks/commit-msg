#!/bin/bash

# =============================================================================
# commit-msg hook for PestPac Mobile
# Validates commit message format. Runs after the message is written.
# Receives the path to the commit message file as $1.
# =============================================================================

# =============================================================================
# CHECK 1 — Commit message format (BLOCKING)
# =============================================================================
echo ""
echo "┌─────────────────────────────────────────────────┐"
echo "│  Check 1: Commit message format                 │"
echo "└─────────────────────────────────────────────────┘"

COMMIT_MSG=$(cat "$1")

# Pattern: [MO-XXX] followed by a space and at least one character
if echo "$COMMIT_MSG" | grep -qE '^\[MO-[0-9]+\] .+'; then
  echo "✓ Commit message format is valid: $COMMIT_MSG"
else
  echo ""
  echo "✗ ERROR: Commit message does not match the required format."
  echo ""
  echo "  Expected:  [MO-XXX] short title"
  echo "  Example:   [MO-1234] Fix crash on login screen"
  echo "  Got:       $COMMIT_MSG"
  echo ""
  echo "  Commit blocked. Please amend your commit message and try again."
  echo ""
  exit 1
fi

exit 0
